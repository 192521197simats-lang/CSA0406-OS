#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/wait.h>

int main() {
    pid_t pid;
    pid = fork();

    if (pid < 0) {
        fprintf(stderr, "Fork Failed\n");
        return 1;
    } 
    else if (pid == 0) {
     
        printf("Child Process: Executing tasks...\n");
        sleep(2); // Simulate work by sleeping for 2 seconds
        printf("Child Process: Completed.\n");
    } 
    else {
 
        printf("Parent Process: Waiting for child...\n");
        
        wait(NULL); 
        
        printf("Parent Process Resumed.\n");
    }

    return 0;
}
