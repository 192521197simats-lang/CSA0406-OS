#include <stdio.h>
#include <unistd.h>
#include <stdlib.h>
#include <sys/types.h>
#include <sys/wait.h>
int main(){
    pid_t pid;
    pid=fork();
    if (pid<0){
        printf("failed to process a child");
        return 1;
    }
    else if(pid ==0){
        printf("Child Process (PID: %d) is running.\n", getpid());
        printf("Child Process is terminating...\n");
        exit(0);
    }
    else {
        wait(NULL);  
        printf("Parent Process (PID: %d): Child has terminated.\n", getpid());
        printf("Parent Process: Execution completed.\n");
    }

    return 0;
}
