#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/wait.h>

int main() {
    pid_t pid = fork();
    if (pid < 0) {
        perror("Fork failed");
        return 1;
    }
    if (pid == 0) {
        printf("Child Process: Executing 'ls -l'...\n");
        
        execlp("ls", "ls", "-l", NULL);

        perror("exec failed");
        exit(1);
    } 
    else {
        wait(NULL);
        printf("Parent Process: Child has finished execution.\n");
    }

    return 0;
}
