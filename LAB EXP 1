#include <stdio.h>
#include <unistd.h>

int main()
{
    pid_t pid;

    pid = fork();

    if (pid == 0)
    {
        printf("Child Process\n");
        printf("Process ID (PID) : %d\n", getpid());
        printf("Parent Process ID (PPID) : %d\n", getppid());
    }
    else if (pid > 0)
    {
        printf("Parent Process\n");
        printf("Process ID (PID) : %d\n", getpid());
        printf("Parent Process ID (PPID) : %d\n", getppid());
    }
    else
    {
        printf("Process creation failed.\n");
    }

    return 0;
}
