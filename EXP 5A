#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/wait.h>

int main() {
    pid_t pid;

    printf("Parent Process: PID = %d, PPID = %d\n", getpid(), getppid());
    printf("-------------------------------------------\n");

    for (int i = 0; i < 3; i++) {
        pid = fork();

        if (pid < 0) {
            perror("Fork failed");
            return 1;
        } 
        else if (pid == 0) {
            printf("[Child %d] PID = %d, PPID = %d\n", i + 1, getpid(), getppid());
          
            return 0; 
        }
    }

    for (int i = 0; i < 3; i++) {
        wait(NULL);
    }

    printf("-------------------------------------------\n");
    printf("Parent process finished.\n");
    return 0;
}
